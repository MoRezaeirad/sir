{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sir.advisory_signal.v0",
  "description": "An advisory provider signal — risk/baseline/model output. Advisory only, never a final decision (PRD §10.6-7).",
  "type": "object",
  "required": [
    "schema_version",
    "provider",
    "risk_level",
    "is_advisory"
  ],
  "properties": {
    "schema_version": { "const": "sir.advisory_signal.v0" },
    "provider": { "type": "string" },
    "risk_level": { "enum": ["low", "medium", "high", "critical"] },
    "reason": { "type": "string" },
    "advisory_signal_type": {
      "enum": [
        "declared_intent", "mediated_action", "observed_runtime",
        "enforced_boundary", "advisory_signal", "user_decision", "admin_policy"
      ]
    },
    "is_advisory": {
      "const": true,
      "description": "Advisory signals can raise risk but can never lower deterministic risk."
    },
    "metadata": { "type": "object" }
  }
}
