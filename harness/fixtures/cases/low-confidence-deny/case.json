{
  "case_id": "low-confidence-deny",
  "title": "Low Confidence Does Not Relax Deny",
  "description": "AI agent reads credentials under low attribution confidence (OS sensor only, no hook). Policy rule deny-agent-credential-read fires. Low confidence must NOT relax the deny to ask — deny is terminal. Mode is os_observed: an OS sensor is the deployed observer, so the post-exec observed_runtime signal is realistic for the mode (a hook_gate fixture may not carry OS-sensor signals).",
  "mode": "os_observed",
  "hook_missing": true,
  "sensitive_source": true,
  "expected": {
    "verdict": "deny",
    "enforceability": "detects",
    "decision_class": "deny_now",
    "policy_rules": ["deny-agent-credential-read"]
  },
  "signals": [
    {
      "schema_version": "sir.signal.v0",
      "signal_id": "sig1",
      "signal_time": "2026-05-31T00:00:00Z",
      "source": {
        "kind": "os_file_sensor",
        "reliability": "observed_runtime",
        "timing": "post_exec",
        "provider": "os_file_sensor",
        "provider_version": "0.1.0"
      },
      "session": {
        "trace_id": "trace_lcd",
        "session_id": "ses_lcd",
        "turn_id": "turn_lcd_1"
      },
      "actor_claim": {
        "kind": "ai_coding_agent",
        "name": "claude-code",
        "pid": 1234,
        "process_tree": ["zsh", "claude"]
      },
      "action_claim": {
        "type": "file_read",
        "target": {
          "display": "~/.aws/credentials",
          "sensitivity": "credential"
        }
      }
    }
  ]
}
